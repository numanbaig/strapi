{
  "kind": "collectionType",
  "collectionName": "leads",
  "info": {
    "singularName": "lead",
    "pluralName": "leads",
    "displayName": "Lead",
    "description": "Stores lead information from forms and bookings"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "maxLength": 255
    },
    "email": {
      "type": "email",
      "required": true
    },
    "phone": {
      "type": "string",
      "maxLength": 50
    },
    "source": {
      "type": "enumeration",
      "enum": ["landing_page", "cal_booking", "referral", "other"],
      "default": "landing_page",
      "required": true
    },
    "status": {
      "type": "enumeration",
      "enum": ["new", "contacted", "qualified", "converted", "lost"],
      "default": "new",
      "required": true
    },
    "crmId": {
      "type": "string",
      "maxLength": 255
    }
  }
}
